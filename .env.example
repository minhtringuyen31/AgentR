# Copy this file to .env and fill in your credentials
# cp .env.example .env

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# MySQL warehouse (GreenNode self-hosted, or your own)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=risk_db
MYSQL_USER=
MYSQL_PASSWORD=

# UI - point to deployed agent or local server (http://localhost:8080)
AGENT_ENDPOINT_URL=

# risk-portal-ui (baked at build time via Docker --build-arg)
VITE_AGENT_URL=http://localhost:8080
VITE_SERVER_URL=
