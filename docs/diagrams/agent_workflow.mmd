flowchart TD
    START([START]) --> INGEST[ingest_node<br/>LLM: ingest]
    INGEST --> ANOMALY[anomaly_check_node<br/>LLM: anomaly + 9-window queries]
    ANOMALY -->|normal| ACTION[action_output_node<br/>NoActionReport]
    ANOMALY -->|anomalous| FETCH[fetch_data_node<br/>targeted retrieval]
    ACTION --> ENDA([END])

    FETCH --> INIT[investigation_init_node<br/>load KB + skill]
    INIT --> PLAN[plan_node<br/>LLM: plan]
    PLAN --> ACT[act_node<br/>dispatch tool]
    ACT --> OBS[observe_node<br/>LLM: observe + 3-layer defense]
    OBS -->|continue| PLAN
    OBS -->|converged / self_declared / max_iter / no_pattern| FINAL[finalize_investigation_node<br/>pick best F1 pattern]
    FINAL --> POLICY[policy_output_node<br/>RuleJSON + pretty_report]
    POLICY --> ENDB([END])

    classDef llm fill:#fde68a,stroke:#b45309,color:#000
    classDef tool fill:#bfdbfe,stroke:#1d4ed8,color:#000
    classDef terminal fill:#fecaca,stroke:#b91c1c,color:#000
    classDef start fill:#bbf7d0,stroke:#15803d,color:#000

    class INGEST,ANOMALY,PLAN,OBS llm
    class FETCH,INIT,ACT,FINAL,POLICY,ACTION tool
    class START,ENDA,ENDB start
